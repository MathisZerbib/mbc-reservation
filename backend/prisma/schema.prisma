generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @unique @default(uuid())
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id          String   @id @unique @default(uuid())
  hashedToken String   @unique
  userId      String
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expireAt    DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Table {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  capacity Int
  type     TableType @default(RECTANGULAR)
  x        Float?
  y        Float?
  bookings Booking[] @relation("BookingTables")
}

model Booking {
  id        String        @id @default(uuid())
  size      Int
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  language  String
  email     String?
  name      String
  phone     String?
  lowTable  Boolean       @default(false)
  tables    Table[]       @relation("BookingTables")
}

enum TableType {
  RECTANGULAR
  OCTAGONAL
  CAPSULE
  ROUND
  BAR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
